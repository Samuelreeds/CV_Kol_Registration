generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model WholesaleApplicant {
  id                   Int      @id @default(autoincrement())
  company_name         String?
  reg_number           String?
  year_established     String?
  business_address     String?
  store_address        String?
  num_stores           String?
  contact_person       String?
  position             String?
  phone                String?
  email                String?
  comm_method          String?
  business_type        String?
  sales_channels       String?
  customer_segment     String?
  interested_products  String?
  monthly_volume       String?
  preferred_package    String?
  payment_method       String?
  payment_term         String?
  applicant_name       String?
  signature            String?
  declaration_date     String?
  business_license_url String?
  store_photos_url     String?
  id_passport_url      String?
  social_links_url     String?
  status               String   @default("Pending")
  created_at           DateTime @default(now())
}

model Influencer {
  id                   Int      @id @default(autoincrement())
  full_name            String?
  phone                String?
  email                String?
  tiktok_link          String?
  instagram_link       String?
  follower_counts      String?
  ugc_experience       String?
  content_samples      String?
  collaboration_reason String?
  status               String   @default("Pending")
  created_at           DateTime @default(now())
}

model UgcCreator {
  id               Int      @id @default(autoincrement())
  full_name        String?
  email            String?
  phone            String?
  shipping_address String?
  dob              String?
  tiktok_handle    String?
  instagram_handle String?
  portfolio_link   String?
  content_niche    String?
  rates            String?
  skin_type        String?
  skin_tone        String?
  skin_concerns    String?
  status           String   @default("Pending")
  created_at       DateTime @default(now())
}

model JobApplicant {
  id               Int      @id @default(autoincrement())
  full_name        String?
  email            String?
  phone            String?
  linkedin_url     String?
  position_applied String?
  expected_salary  String?
  start_date       String?
  resume_url       String?
  cover_letter     String?
  status           String   @default("Pending")
  created_at       DateTime @default(now())
}

model Position {
  id         Int      @id @default(autoincrement())
  title      String
  created_at DateTime @default(now())
}